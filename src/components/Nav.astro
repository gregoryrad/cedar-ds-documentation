---
const currentPath = Astro.url.pathname;

const tokenLinks = [
  { href: '/tokens/color', label: 'Color' },
  { href: '/tokens/spacing', label: 'Spacing' },
  { href: '/tokens/radius', label: 'Radius' },
  { href: '/tokens/typography', label: 'Typography' },
  { href: '/tokens/border', label: 'Border' },
];

const componentLinks = [
  { href: '/components/button', label: 'Button' },
  { href: '/components/input', label: 'Input' },
  { href: '/components/checkbox', label: 'Checkbox' },
  { href: '/components/badge', label: 'Badge' },
  { href: '/components/card', label: 'Card' },
  { href: '/components/alert', label: 'Alert' },
  { href: '/components/status', label: 'Status' },
  { href: '/components/tabs', label: 'Tabs' },
  { href: '/components/modal', label: 'Modal' },
  { href: '/components/toast', label: 'Toast' },
  { href: '/components/tooltip', label: 'Tooltip' },
  { href: '/components/breadcrumb', label: 'Breadcrumb' },
  { href: '/components/pagination', label: 'Pagination' },
  { href: '/components/menu', label: 'Menu' },
  { href: '/components/select', label: 'Select' },
  { href: '/components/toggle', label: 'Toggle' },
  { href: '/components/radio', label: 'Radio' },
  { href: '/components/icon-button', label: 'Icon Button' },
  { href: '/components/avatar', label: 'Avatar' },
  { href: '/components/divider', label: 'Divider' },
];

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + '/');
}

const isTokens = currentPath.startsWith('/tokens');
const isComponents = currentPath.startsWith('/components');
---

<nav aria-label="Site navigation">
  <div class="nav-inner">
    <a href="/" class="wordmark" aria-label="Cedar DS home">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <rect width="24" height="24" rx="6" fill="var(--action-primary)" />
        <g transform="scale(0.75)">
          <path d="M16.0001 26V23M21.0001 18L24.0001 21.3C24.1371 21.4398 24.2301 21.6167 24.2676 21.8088C24.305 22.001 24.2852 22.1998 24.2107 22.3808C24.1362 22.5618 24.0102 22.717 23.8483 22.8271C23.6864 22.9371 23.4958 22.9973 23.3001 23H8.70007C8.50434 22.9973 8.31372 22.9371 8.15185 22.8271C7.98998 22.717 7.86396 22.5618 7.78943 22.3808C7.7149 22.1998 7.69513 22.001 7.73258 21.8088C7.77002 21.6167 7.86302 21.4398 8.00007 21.3L11.0001 18H10.7001C10.5043 17.9973 10.3137 17.9371 10.1519 17.8271C9.98998 17.717 9.86396 17.5619 9.78943 17.3808C9.7149 17.1998 9.69513 17.001 9.73258 16.8088C9.77002 16.6167 9.86302 16.4398 10.0001 16.3L13.0001 13H12.8001C12.5958 13.0184 12.3908 12.9736 12.2129 12.8716C12.035 12.7696 11.8927 12.6154 11.8054 12.4298C11.7181 12.2443 11.6899 12.0364 11.7247 11.8343C11.7596 11.6322 11.8557 11.4456 12.0001 11.3L16.0001 7L20.0001 11.3C20.1445 11.4456 20.2406 11.6322 20.2754 11.8343C20.3102 12.0364 20.2821 12.2443 20.1947 12.4298C20.1074 12.6154 19.9651 12.7696 19.7872 12.8716C19.6093 12.9736 19.4043 13.0184 19.2001 13H19.0001L22.0001 16.3C22.1371 16.4398 22.2301 16.6167 22.2676 16.8088C22.305 17.001 22.2852 17.1998 22.2107 17.3808C22.1362 17.5619 22.0102 17.717 21.8483 17.8271C21.6864 17.9371 21.4958 17.9973 21.3001 18H21.0001Z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </g>
      </svg>
      <span>Cedar DS</span>
    </a>

    <ul class="nav-links" role="list">
      <li class="nav-group">
        <button
          class:list={['nav-group-trigger', { 'is-active': isTokens }]}
          aria-expanded={isTokens}
          aria-haspopup="true"
        >
          Tokens
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <ul class="nav-dropdown" role="list">
          {tokenLinks.map(link => (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { 'is-active': isActive(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </li>

      <li class="nav-group">
        <button
          class:list={['nav-group-trigger', { 'is-active': isComponents }]}
          aria-expanded={isComponents}
          aria-haspopup="true"
        >
          Components
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <ul class="nav-dropdown" role="list">
          {componentLinks.map(link => (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { 'is-active': isActive(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </li>

      <li>
        <a
          href="/built-with-cedar"
          class:list={['nav-link', { 'is-active': isActive('/built-with-cedar') }]}
        >
          Built with Cedar
        </a>
      </li>

      <li>
        <a
          href="/roadmap"
          class:list={['nav-link', { 'is-active': isActive('/roadmap') }]}
        >
          Roadmap
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--bg-base);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
  }

  .nav-inner {
    max-width: var(--grid-max-width);
    margin: 0 auto;
    padding: 0 var(--grid-margin);
    height: 56px;
    display: flex;
    align-items: center;
    gap: var(--space-8);
  }

  .wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
    font-size: var(--body-md);
    font-weight: 600;
    color: var(--text-base);
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    align-items: stretch;
    align-self: stretch;
    gap: var(--space-1);
    list-style: none;
  }

  .nav-links > li {
    display: flex;
    align-items: center;
  }

  .nav-group {
    position: relative;
    display: flex;
    align-items: center;
  }

  .nav-group:hover .nav-dropdown {
    display: flex;
  }

  .nav-group-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: var(--space-1) var(--space-3);
    border: none;
    background: none;
    cursor: pointer;
    font-family: var(--font-base);
    font-size: var(--body-sm);
    color: var(--text-subtle);
    border-radius: var(--radius-md);
    transition: color 0.15s, background-color 0.15s;
  }

  .nav-group-trigger:hover,
  .nav-group-trigger.is-active {
    color: var(--text-base);
    background-color: var(--bg-faint);
  }

  .nav-dropdown {
    display: none;
    flex-direction: column;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: var(--bg-base);
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-2);
    min-width: 160px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    list-style: none;
    gap: 2px;
  }

  .nav-link {
    display: block;
    padding: var(--space-1) var(--space-3);
    text-decoration: none;
    font-size: var(--body-sm);
    color: var(--text-subtle);
    border-radius: var(--radius-md);
    transition: color 0.15s, background-color 0.15s;
  }

  .nav-link:hover {
    color: var(--text-base);
    background-color: var(--bg-faint);
  }

  .nav-link.is-active {
    color: var(--action-primary);
    font-weight: 500;
    background-color: var(--bg-faint);
  }
</style>

<script>
  // Toggle dropdowns on click for keyboard/touch support
  document.querySelectorAll('.nav-group-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const group = trigger.closest('.nav-group');
      const dropdown = group?.querySelector('.nav-dropdown') as HTMLElement | null;
      if (!dropdown) return;
      const isOpen = dropdown.style.display === 'flex';
      dropdown.style.display = isOpen ? '' : 'flex';
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('.nav-group')) {
      document.querySelectorAll('.nav-dropdown').forEach(d => {
        (d as HTMLElement).style.display = '';
      });
    }
  });
</script>
