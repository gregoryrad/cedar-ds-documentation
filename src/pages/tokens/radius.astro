---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PageContent from '../../components/PageContent.astro';

const tokens = [
  { name: 'radius/none', var: '--radius-none', value: '0px',   alias: 'scale/0',    note: 'Sharp edges — use for data-dense UIs like tables and grid cells.' },
  { name: 'radius/sm',   var: '--radius-sm',   value: '4px',   alias: 'scale/100',  note: 'Subtle rounding. Checkbox boxes, small chips, code blocks.' },
  { name: 'radius/md',   var: '--radius-md',   value: '8px',   alias: 'scale/200',  note: 'Standard rounding. Input fields, cards, data grid cells.' },
  { name: 'radius/lg',   var: '--radius-lg',   value: '12px',  alias: 'scale/300',  note: 'Prominent rounding. Buttons, dropdown menus, tooltips.' },
  { name: 'radius/xl',   var: '--radius-xl',   value: '16px',  alias: 'scale/400',  note: 'Large rounding. Feature cards, modals, large panels.' },
  { name: 'radius/full', var: '--radius-full', value: '999px', alias: 'scale/1800', note: 'Pill shape. Badges, chips, avatar frames.' },
];
---

<BaseLayout title="Radius tokens">
  <PageHeader
    eyebrow="Tokens"
    title="Radius"
    description="Six radius steps covering the full spectrum from sharp data-dense contexts to pill-shaped interactive elements. Cedar uses border-radius consistently — no arbitrary values."
  />

  <PageContent>
    <section class="demo-section">
      {tokens.map(t => (
        <div class="radius-row">
          <div class="radius-demo" style={`border-radius: var(${t.var})`} />
          <div class="radius-meta">
            <code class="token-name">{t.name}</code>
            <div class="token-details">
              <code class="token-var">{t.var}</code>
              <span class="sep">·</span>
              <code class="token-value">{t.value}</code>
              <span class="sep">·</span>
              <code class="token-alias">↳ {t.alias}</code>
            </div>
            <p class="token-note">{t.note}</p>
          </div>
        </div>
      ))}
    </section>
  </PageContent>
</BaseLayout>

<style>
  .demo-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .radius-row {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-4);
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: var(--bg-base);
  }

  .radius-demo {
    width: 80px;
    height: 80px;
    background-color: var(--action-primary);
    flex-shrink: 0;
    opacity: 0.85;
  }

  .radius-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .token-name {
    font-family: var(--font-mono);
    font-size: var(--body-sm);
    font-weight: 600;
    color: var(--text-base);
  }

  .token-details {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .token-var, .token-value, .token-alias {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-subtle);
  }

  .sep { color: var(--border-subtle); }

  .token-note {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    margin-top: var(--space-1);
    line-height: 1.5;
  }
</style>
