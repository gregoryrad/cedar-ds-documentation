---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PageContent from '../../components/PageContent.astro';

const spaceTokens = [
  { name: 'space/0',  var: '--space-0',  value: '0px',  scale: 0 },
  { name: 'space/1',  var: '--space-1',  value: '4px',  scale: 4 },
  { name: 'space/2',  var: '--space-2',  value: '8px',  scale: 8 },
  { name: 'space/3',  var: '--space-3',  value: '12px', scale: 12 },
  { name: 'space/4',  var: '--space-4',  value: '16px', scale: 16 },
  { name: 'space/5',  var: '--space-5',  value: '20px', scale: 20 },
  { name: 'space/6',  var: '--space-6',  value: '24px', scale: 24 },
  { name: 'space/8',  var: '--space-8',  value: '32px', scale: 32 },
  { name: 'space/10', var: '--space-10', value: '40px', scale: 40 },
];

const scaleTokens = [
  { name: 'scale/0',    var: '--scale-0',    value: '0px'   },
  { name: 'scale/25',   var: '--scale-25',   value: '1px'   },
  { name: 'scale/50',   var: '--scale-50',   value: '2px'   },
  { name: 'scale/100',  var: '--scale-100',  value: '4px'   },
  { name: 'scale/200',  var: '--scale-200',  value: '8px'   },
  { name: 'scale/300',  var: '--scale-300',  value: '12px'  },
  { name: 'scale/400',  var: '--scale-400',  value: '16px'  },
  { name: 'scale/500',  var: '--scale-500',  value: '20px'  },
  { name: 'scale/600',  var: '--scale-600',  value: '24px'  },
  { name: 'scale/700',  var: '--scale-700',  value: '28px'  },
  { name: 'scale/800',  var: '--scale-800',  value: '32px'  },
  { name: 'scale/900',  var: '--scale-900',  value: '36px'  },
  { name: 'scale/1000', var: '--scale-1000', value: '40px'  },
  { name: 'scale/1100', var: '--scale-1100', value: '48px'  },
  { name: 'scale/1200', var: '--scale-1200', value: '56px'  },
  { name: 'scale/1300', var: '--scale-1300', value: '64px'  },
  { name: 'scale/1400', var: '--scale-1400', value: '72px'  },
  { name: 'scale/1500', var: '--scale-1500', value: '96px'  },
  { name: 'scale/1600', var: '--scale-1600', value: '128px' },
];
---

<BaseLayout title="Spacing tokens">
  <PageHeader
    eyebrow="Tokens"
    title="Spacing"
    description="Cedar's spacing system is built on a 4px base grid. The raw scale (scale/*) provides granular control; named space tokens (space/*) are the preferred API for components."
  />

  <PageContent>
    <section>
      <h2 class="sub-title">Named space tokens</h2>
      <p class="sub-desc">Use these in components. Note: space/7 and space/9 are intentionally absent — 28px and 36px are accessible via scale/700 and scale/900 when needed.</p>

      <div class="token-table">
        <div class="table-header">
          <span>Token</span><span>CSS var</span><span>Value</span><span>Visual</span>
        </div>
        {spaceTokens.map(t => (
          <div class="table-row">
            <code class="token-name">{t.name}</code>
            <code class="token-var">{t.var}</code>
            <code class="token-value">{t.value}</code>
            <div class="space-bar-cell">
              <div
                class="space-bar"
                style={t.scale > 0 ? `width: ${Math.min(t.scale * 4, 200)}px` : 'width: 2px; background: var(--border-subtle)'}
              />
            </div>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="sub-title">Raw scale</h2>
      <p class="sub-desc">The primitive scale backing the space tokens. Built on a 4px base unit (scale/100 = 4px). Scale values above 1000 are used for layout-level distances and radius utilities.</p>

      <div class="token-table">
        <div class="table-header">
          <span>Token</span><span>CSS var</span><span>Value</span><span>Visual</span>
        </div>
        {scaleTokens.map(t => (
          <div class="table-row">
            <code class="token-name">{t.name}</code>
            <code class="token-var">{t.var}</code>
            <code class="token-value">{t.value}</code>
            <div class="space-bar-cell">
              <div
                class="space-bar"
                style={`width: ${Math.min(parseInt(t.value) * 3, 200)}px`}
              />
            </div>
          </div>
        ))}
      </div>
    </section>
  </PageContent>
</BaseLayout>

<style>
  .sub-title {
    font-size: var(--heading-lg);
    font-weight: 700;
    color: var(--text-base);
    margin-bottom: var(--space-2);
  }

  .sub-desc {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    margin-bottom: var(--space-5);
    max-width: 560px;
    line-height: 1.6;
  }

  .token-table {
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .table-header {
    display: grid;
    grid-template-columns: 2fr 2fr 1fr 3fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-faint);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    font-size: var(--size-xs);
    font-weight: 600;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .table-row {
    display: grid;
    grid-template-columns: 2fr 2fr 1fr 3fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    align-items: center;
  }

  .table-row:last-child { border-bottom: none; }
  .table-row:hover { background: var(--bg-faint); }

  .token-name, .token-var, .token-value {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-subtle);
  }

  .token-name { color: var(--text-base); }

  .space-bar-cell {
    display: flex;
    align-items: center;
  }

  .space-bar {
    height: 8px;
    background-color: var(--action-primary);
    border-radius: var(--radius-sm);
    min-width: 2px;
    opacity: 0.7;
  }
</style>
