---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PageContent from '../../components/PageContent.astro';

const sizeTokens = [
  { name: 'size/xs',  var: '--size-xs',  mobile: '12px', desktop: '14px' },
  { name: 'size/sm',  var: '--size-sm',  mobile: '16px', desktop: '18px' },
  { name: 'size/md',  var: '--size-md',  mobile: '18px', desktop: '20px' },
  { name: 'size/lg',  var: '--size-lg',  mobile: '20px', desktop: '24px' },
  { name: 'size/xl',  var: '--size-xl',  mobile: '24px', desktop: '32px' },
  { name: 'size/2xl', var: '--size-2xl', mobile: '32px', desktop: '40px' },
  { name: 'size/3xl', var: '--size-3xl', mobile: '40px', desktop: '56px' },
  { name: 'size/4xl', var: '--size-4xl', mobile: '48px', desktop: '72px' },
];

const roleTokens = [
  { name: 'body/sm',    var: '--body-sm',    value: '16px', specimen: 'The quick brown fox jumps over the lazy dog.' },
  { name: 'body/md',    var: '--body-md',    value: '18px', specimen: 'The quick brown fox jumps over the lazy dog.' },
  { name: 'body/lg',    var: '--body-lg',    value: '20px', specimen: 'The quick brown fox jumps over the lazy dog.' },
  { name: 'heading/sm', var: '--heading-sm', value: '18px', specimen: 'Section heading, small' },
  { name: 'heading/md', var: '--heading-md', value: '20px', specimen: 'Section heading, medium' },
  { name: 'heading/lg', var: '--heading-lg', value: '24px', specimen: 'Section heading, large' },
  { name: 'title/sm',   var: '--title-sm',   value: '20px', specimen: 'Page title, small' },
  { name: 'title/md',   var: '--title-md',   value: '24px', specimen: 'Page title, medium' },
  { name: 'title/lg',   var: '--title-lg',   value: '32px', specimen: 'Page title, large' },
];
---

<BaseLayout title="Typography tokens">
  <PageHeader
    eyebrow="Tokens"
    title="Typography"
    description="Cedar's type system is defined entirely as Figma variables. Two font families (Inter for UI, Fira Code for mono), a responsive size scale with Mobile and Desktop modes, and nine semantic role tokens."
  />

  <PageContent>
    <section>
      <h2 class="sub-title">Font families</h2>
      <div class="font-cards">
        <div class="font-card">
          <p class="font-label"><code>font/base · --font-base</code></p>
          <p class="font-specimen" style="font-family: var(--font-base)">Inter — UI typeface</p>
          <p class="font-meta">Used for all UI text, labels, and body copy.</p>
        </div>
        <div class="font-card">
          <p class="font-label"><code>font/mono · --font-mono</code></p>
          <p class="font-specimen" style="font-family: var(--font-mono); font-size: var(--heading-md)">Fira Code — monospace</p>
          <p class="font-meta">Used for token names, code examples, and technical references.</p>
        </div>
      </div>
    </section>

    <section>
      <h2 class="sub-title">Size scale <span class="responsive-badge">Responsive</span></h2>
      <p class="sub-desc">Type sizes use Figma's variable modes to define separate Mobile and Desktop values. The CSS custom properties respond to viewport via media query.</p>

      <div class="token-table">
        <div class="table-header">
          <span>Token</span><span>CSS var</span><span>Mobile</span><span>Desktop</span>
        </div>
        {sizeTokens.map(t => (
          <div class="table-row">
            <code class="token-name">{t.name}</code>
            <code class="token-var">{t.var}</code>
            <code class="token-value">{t.mobile}</code>
            <code class="token-value">{t.desktop}</code>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="sub-title">Role tokens</h2>
      <p class="sub-desc">Semantic font-size roles that components use directly. Hardcoded at desktop values — a planned v2 improvement is to alias these to the responsive size tokens.</p>

      <div class="role-specimens">
        {roleTokens.map(t => (
          <div class="role-row">
            <div class="role-specimen" style={`font-size: var(${t.var}); font-family: var(--font-base)`}>
              {t.specimen}
            </div>
            <div class="role-meta">
              <code class="token-name">{t.name}</code>
              <span class="sep">·</span>
              <code class="token-var">{t.var}</code>
              <span class="sep">·</span>
              <code class="token-value">{t.value}</code>
            </div>
          </div>
        ))}
      </div>
    </section>
  </PageContent>
</BaseLayout>

<style>
  .sub-title {
    font-size: var(--heading-lg);
    font-weight: 700;
    color: var(--text-base);
    margin-bottom: var(--space-2);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .responsive-badge {
    font-size: var(--size-xs);
    font-weight: 600;
    background: var(--status-information-bg);
    color: var(--status-information);
    padding: 2px 8px;
    border-radius: var(--radius-full);
    letter-spacing: 0.04em;
  }

  .sub-desc {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    margin-bottom: var(--space-5);
    max-width: 560px;
    line-height: 1.6;
  }

  .font-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-bottom: 0;
  }

  @media (max-width: 767px) {
    .font-cards { grid-template-columns: 1fr; }
  }

  .font-card {
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    background: var(--bg-base);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .font-label code {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-subtle);
  }

  .font-specimen {
    font-size: var(--heading-lg);
    font-weight: 500;
    color: var(--text-base);
  }

  .font-meta {
    font-size: var(--body-sm);
    color: var(--text-subtle);
  }

  .token-table {
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .table-header {
    display: grid;
    grid-template-columns: 2fr 2fr 1fr 1fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background: var(--bg-faint);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    font-size: var(--size-xs);
    font-weight: 600;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .table-row {
    display: grid;
    grid-template-columns: 2fr 2fr 1fr 1fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    align-items: center;
  }

  .table-row:last-child { border-bottom: none; }
  .table-row:hover { background: var(--bg-faint); }

  .token-name, .token-var, .token-value {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-subtle);
  }

  .token-name { color: var(--text-base); }

  .role-specimens {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-base);
  }

  .role-row {
    padding: var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .role-row:last-child { border-bottom: none; }
  .role-row:hover { background: var(--bg-faint); }

  .role-specimen {
    color: var(--text-base);
    line-height: 1.3;
  }

  .role-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .sep { color: var(--border-subtle); font-size: var(--size-xs); }
</style>
