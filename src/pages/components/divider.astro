---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PageContent from '../../components/PageContent.astro';
import {
  DividerVariants,
  DividerWithLabel,
  DividerVertical,
  DividerInSettings,
} from '../../cedar/components/Divider/DividerDemo';
import { Badge } from '../../cedar/components/Badge/Badge';
---

<BaseLayout title="Divider">
  <PageHeader
    eyebrow="Components"
    title="Divider"
    description="A thin line that separates groups of content. Comes in horizontal and vertical orientations, three weight variants, and an optional centered text label."
  />

  <PageContent>

    <!-- Variants -->
    <section>
      <h2 class="section-title">Variants</h2>
      <p class="section-desc">Three color weights map to Cedar border tokens. <code>subtle</code> is the default and right for most separations — <code>strong</code> is reserved for major section breaks.</p>
      <div class="demo-block">
        <div class="demo-row">
          <DividerVariants client:load />
        </div>
      </div>
    </section>

    <!-- With label -->
    <section>
      <h2 class="section-title">With label</h2>
      <p class="section-desc">Pass a <code>label</code> prop to place text centered on the divider line. Common for "Or continue with" auth flows and named section breaks.</p>
      <div class="demo-block">
        <div class="demo-row">
          <DividerWithLabel client:load />
        </div>
      </div>
    </section>

    <!-- Vertical -->
    <section>
      <h2 class="section-title">Vertical</h2>
      <p class="section-desc">Set <code>orientation="vertical"</code> to create an inline separator. The divider stretches to the height of its flex container via <code>align-self: stretch</code>.</p>
      <div class="demo-block">
        <div class="demo-row">
          <DividerVertical client:load />
        </div>
      </div>
    </section>

    <!-- In context -->
    <section>
      <h2 class="section-title">In context — settings rows</h2>
      <p class="section-desc">The most common pattern: subtle horizontal dividers between rows inside a settings panel or card.</p>
      <div class="demo-block">
        <div class="demo-row">
          <DividerInSettings client:load />
        </div>
      </div>
    </section>

    <!-- Props -->
    <section>
      <h2 class="section-title">Props</h2>
      <div class="token-table">
        {[
          { prop: 'variant',      type: '"subtle" | "base" | "strong"',       default: '"subtle"',     desc: 'Line color weight.' },
          { prop: 'orientation',  type: '"horizontal" | "vertical"',           default: '"horizontal"', desc: 'Axis of the divider.' },
          { prop: 'label',        type: 'string',                              default: '—',            desc: 'Centered text. Horizontal only.' },
          { prop: 'decorative',   type: 'boolean',                             default: 'true',         desc: 'When true: role="none" aria-hidden. Set false when the divider carries semantic meaning.' },
        ].map(row => (
          <div class="token-row prop-row">
            <code class="token-name">{row.prop}</code>
            <code class="token-name">{row.type}</code>
            <code class="token-name">{row.default}</code>
            <span class="token-usage">{row.desc}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Accessibility -->
    <section>
      <h2 class="section-title">Accessibility</h2>
      <div class="token-table">
        {[
          { key: 'decorative=true (default)', desc: 'Sets role="none" aria-hidden="true". Screen readers skip it — correct for the vast majority of dividers that are purely visual.' },
          { key: 'decorative=false',          desc: 'Sets role="separator". Use when the divider marks a meaningful boundary that a screen reader user needs to know about.' },
          { key: 'aria-label (with label)',   desc: 'When decorative=false and a label is set, the label text becomes the accessible name of the separator.' },
          { key: 'aria-orientation',          desc: 'Set to "vertical" on vertical dividers so assistive technology announces the orientation correctly.' },
        ].map(row => (
          <div class="token-row">
            <code class="token-name">{row.key}</code>
            <span class="token-usage">{row.desc}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Usage -->
    <section>
      <h2 class="section-title">Usage guidance</h2>
      <div class="token-table">
        {[
          { rule: 'Do',    desc: 'Use subtle dividers between rows in lists, tables, and settings panels.' },
          { rule: 'Do',    desc: 'Use the label variant to name sections within a single scrollable panel.' },
          { rule: 'Do',    desc: 'Use vertical dividers inside flex toolbars to group related actions.' },
          { rule: "Don't", desc: 'Use dividers as a substitute for spacing. If content just needs more breathing room, increase gap or padding instead.' },
          { rule: "Don't", desc: 'Use strong dividers between every row — reserve them for top-level section breaks.' },
          { rule: "Don't", desc: 'Stack two dividers back to back. Use a single divider or a section header instead.' },
        ].map(row => (
          <div class="token-row">
            <code class:list={['token-name', row.rule === "Don't" ? 'token-dont' : 'token-do']}>{row.rule}</code>
            <span class="token-usage">{row.desc}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Tokens -->
    <section>
      <h2 class="section-title">Tokens used</h2>
      <div class="token-table">
        {[
          { token: 'border/subtle',  usage: 'subtle variant color (default)' },
          { token: 'border/base',    usage: 'base variant color' },
          { token: 'border/base (2px)', usage: 'strong variant — same color as base, doubled weight' },
          { token: 'text/subtle',    usage: 'Label text color' },
          { token: 'space/3',        usage: 'Gap between label and line ends (12px)' },
          { token: 'font/base',      usage: 'Label typeface' },
          { token: 'size/xs',        usage: 'Label font size' },
        ].map(row => (
          <div class="token-row">
            <code class="token-name">{row.token}</code>
            <span class="token-usage">{row.usage}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <div class="figma-meta">
        <Badge color="information" badgeStyle="subtle" client:load>Figma: In progress</Badge>
        <Badge color="success" badgeStyle="subtle" client:load>React: v1</Badge>
      </div>
    </section>

  </PageContent>
</BaseLayout>

<style>
  .section-title {
    font-size: var(--heading-lg);
    font-weight: 700;
    color: var(--text-base);
    margin-bottom: var(--space-2);
  }

  .section-desc {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    margin-bottom: var(--space-4);
    max-width: 560px;
    line-height: 1.6;
  }

  .section-desc code {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    background: var(--bg-muted);
    padding: 1px 5px;
    border-radius: var(--radius-sm);
    color: var(--text-base);
  }

  .demo-block {
    background: var(--bg-base);
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .demo-row {
    padding: var(--space-5);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
  }

  .demo-row:last-child { border-bottom: none; }

  .token-table {
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-base);
  }

  .token-row {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    align-items: center;
  }

  .prop-row { grid-template-columns: 1fr 1.5fr 0.75fr 2fr; }

  .token-row:last-child { border-bottom: none; }
  .token-row:hover { background: var(--bg-faint); }

  .token-name {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-base);
  }

  .token-do   { color: var(--status-success); }
  .token-dont { color: var(--status-error); }

  .token-usage {
    font-size: var(--body-sm);
    color: var(--text-subtle);
  }

  .figma-meta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
</style>
