---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PageContent from '../../components/PageContent.astro';
import { Badge } from '../../cedar/components/Badge/Badge';
---

<BaseLayout title="Tabs">
  <PageHeader
    eyebrow="Components"
    title="Tabs"
    description="Tab navigation for switching between content panels. Two states: Active and Inactive. React implementation in progress."
  />

  <PageContent>
    <section>
      <div class="status-block">
        <div class="status-row">
          <Badge color="success" badgeStyle="subtle" client:load>Figma: Done — Tab Item × 2 + Tab Bar</Badge>
          <Badge color="warning" badgeStyle="subtle" client:load>React: In progress</Badge>
        </div>
        <p class="status-desc">
          The Tabs component follows a familiar Active/Inactive state model. The Tab Bar
          is a composited standalone component assembling multiple Tab Items into a full
          navigation strip.
        </p>
      </div>
    </section>

    <section>
      <h2 class="section-title">Structure</h2>
      <div class="structure-table">
        {[
          { component: 'Tab Item / State=Active',   desc: 'Currently selected tab. Bold label, underline accent in action/primary.' },
          { component: 'Tab Item / State=Inactive', desc: 'Unselected tab. Subdued text/subtle label, no underline.' },
          { component: 'Tab Bar',                   desc: 'Assembled strip of Tab Items with a bottom divider.' },
        ].map(row => (
          <div class="structure-row">
            <code class="comp-name">{row.component}</code>
            <p class="comp-desc">{row.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section>
      <h2 class="section-title">Planned tokens</h2>
      <div class="token-table">
        {[
          { token: 'action/primary', usage: 'Active tab underline' },
          { token: 'text/base', usage: 'Active tab label' },
          { token: 'text/subtle', usage: 'Inactive tab label' },
          { token: 'border/subtle', usage: 'Tab bar bottom border' },
          { token: 'border-width/bold', usage: 'Active underline thickness (2px)' },
        ].map(row => (
          <div class="token-row">
            <code class="token-name">{row.token}</code>
            <span class="token-usage">{row.usage}</span>
          </div>
        ))}
      </div>
    </section>
  </PageContent>
</BaseLayout>

<style>
  .status-block {
    background: var(--bg-base);
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .status-row {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .status-desc {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    line-height: 1.6;
    max-width: 560px;
  }

  .section-title {
    font-size: var(--heading-lg);
    font-weight: 700;
    color: var(--text-base);
    margin-bottom: var(--space-4);
  }

  .structure-table, .token-table {
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-base);
  }

  .structure-row {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    align-items: center;
  }

  .structure-row:last-child { border-bottom: none; }
  .structure-row:hover { background: var(--bg-faint); }

  .comp-name {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-base);
    font-weight: 600;
  }

  .comp-desc {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    line-height: 1.5;
  }

  .token-row {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    align-items: center;
  }

  .token-row:last-child { border-bottom: none; }
  .token-row:hover { background: var(--bg-faint); }

  .token-name {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-base);
  }

  .token-usage {
    font-size: var(--body-sm);
    color: var(--text-subtle);
  }
</style>
