---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PageContent from '../../components/PageContent.astro';
import { TabsDemo } from '../../cedar/components/Tabs/TabsDemo';
import { Badge } from '../../cedar/components/Badge/Badge';
---

<BaseLayout title="Tabs">
  <PageHeader
    eyebrow="Components"
    title="Tabs"
    description="Tab navigation for switching between content panels. Two states: Active and Inactive. Full keyboard navigation — arrow keys, Home, End."
  />

  <PageContent>
    <!-- Live demo -->
    <section>
      <h2 class="section-title">Live demo</h2>
      <p class="section-desc">Click or use arrow keys to switch tabs. Active tab shows a 2px teal indicator; inactive tabs use subdued text.</p>
      <div class="demo-wrap">
        <TabsDemo client:load />
      </div>
    </section>

    <!-- States -->
    <section>
      <h2 class="section-title">States</h2>
      <div class="token-table">
        {[
          { state: 'Active',   desc: 'Semi-bold label in action/primary (teal). 2px bottom indicator in the same token.' },
          { state: 'Inactive', desc: 'Regular-weight label in text/subtle. No indicator.' },
        ].map(row => (
          <div class="token-row">
            <code class="token-name">{row.state}</code>
            <span class="token-usage">{row.desc}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Keyboard -->
    <section>
      <h2 class="section-title">Keyboard navigation</h2>
      <div class="token-table">
        {[
          { key: '← / →',    desc: 'Move focus between tabs; activates focused tab.' },
          { key: 'Home',     desc: 'Move focus to first tab.' },
          { key: 'End',      desc: 'Move focus to last tab.' },
          { key: 'Tab',      desc: 'Move focus out of the tab list into the panel.' },
        ].map(row => (
          <div class="token-row">
            <code class="token-name">{row.key}</code>
            <span class="token-usage">{row.desc}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- Tokens -->
    <section>
      <h2 class="section-title">Tokens used</h2>
      <div class="token-table">
        {[
          { token: 'action/primary',   usage: 'Active tab label color + indicator bar' },
          { token: 'text/subtle',      usage: 'Inactive tab label color' },
          { token: 'border/subtle',    usage: 'Tab bar bottom border' },
          { token: 'font/base',        usage: 'Label typeface (Inter)' },
        ].map(row => (
          <div class="token-row">
            <code class="token-name">{row.token}</code>
            <span class="token-usage">{row.usage}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <div class="figma-meta">
        <Badge color="success" badgeStyle="subtle" client:load>Figma: Done — Tab Item × 2 + Tab Bar</Badge>
        <Badge color="success" badgeStyle="subtle" client:load>React: v1</Badge>
        <Badge color="information" badgeStyle="subtle" client:load>Controlled mode: v2</Badge>
      </div>
    </section>
  </PageContent>
</BaseLayout>

<style>
  .section-title {
    font-size: var(--heading-lg);
    font-weight: 700;
    color: var(--text-base);
    margin-bottom: var(--space-2);
  }

  .section-desc {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    margin-bottom: var(--space-4);
    max-width: 560px;
    line-height: 1.6;
  }

  .demo-wrap {
    background: var(--bg-base);
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
  }

  .panel-content p {
    font-family: var(--font-base);
    font-size: var(--body-md);
    color: var(--text-subtle);
    margin: 0;
  }

  .token-table {
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-base);
  }

  .token-row {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    align-items: center;
  }

  .token-row:last-child { border-bottom: none; }
  .token-row:hover { background: var(--bg-faint); }

  .token-name {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-base);
  }

  .token-usage {
    font-size: var(--body-sm);
    color: var(--text-subtle);
  }

  .figma-meta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
</style>
