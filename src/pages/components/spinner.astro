---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import PageContent from '../../components/PageContent.astro';
import { Spinner } from '../../cedar/components/Spinner/Spinner';
---

<BaseLayout title="Spinner">
  <PageHeader
    eyebrow="Components"
    title="Spinner"
    description="Indeterminate loading indicator for async operations. Three sizes, token-driven colors."
  />

  <PageContent>
    <section>
      <h2 class="section-title">Sizes</h2>
      <div class="demo-block">
        <div class="spinner-row">
          <div class="spinner-item">
            <Spinner size="sm" client:load />
            <code class="label">sm · 16px</code>
          </div>
          <div class="spinner-item">
            <Spinner size="md" client:load />
            <code class="label">md · 24px</code>
          </div>
          <div class="spinner-item">
            <Spinner size="lg" client:load />
            <code class="label">lg · 32px</code>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-title">Colors</h2>
      <div class="demo-block">
        <div class="spinner-row">
          <div class="spinner-item">
            <Spinner size="md" color="var(--action-primary)" client:load />
            <code class="label">action/primary</code>
          </div>
          <div class="spinner-item">
            <Spinner size="md" color="var(--action-secondary)" client:load />
            <code class="label">action/secondary</code>
          </div>
          <div class="spinner-item">
            <Spinner size="md" color="var(--status-error)" client:load />
            <code class="label">status/error</code>
          </div>
          <div class="spinner-item">
            <Spinner size="md" color="var(--text-subtle)" client:load />
            <code class="label">text/subtle</code>
          </div>
        </div>
      </div>
    </section>

    <section>
      <h2 class="section-title">Tokens used</h2>
      <div class="token-table">
        {[
          { token: 'action/primary', usage: 'Spinner arc (default color)' },
          { token: 'border/subtle',  usage: 'Spinner background ring' },
        ].map(row => (
          <div class="token-row">
            <code class="token-name">{row.token}</code>
            <span class="token-usage">{row.usage}</span>
          </div>
        ))}
      </div>
    </section>
  </PageContent>
</BaseLayout>

<style>
  .section-title {
    font-size: var(--heading-lg);
    font-weight: 700;
    color: var(--text-base);
    margin-bottom: var(--space-4);
  }

  .demo-block {
    background: var(--bg-base);
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .spinner-row {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .spinner-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .label {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-subtle);
  }

  .token-table {
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-base);
  }

  .token-row {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    align-items: center;
  }

  .token-row:last-child { border-bottom: none; }
  .token-row:hover { background: var(--bg-faint); }

  .token-name {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-base);
  }

  .token-usage {
    font-size: var(--body-sm);
    color: var(--text-subtle);
  }
</style>
