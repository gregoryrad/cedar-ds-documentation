---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageContent from '../components/PageContent.astro';
import { Badge } from '../cedar/components/Badge/Badge';

const v1 = [
  { item: 'Token pages: Color, Spacing (+ Grid/Layout responsive collection), Radius, Typography, Border' },
  { item: 'Color palette synced to Foundations: primary→teal, secondary (was amber)→blue, accent (was sienna)→green, success→muted green' },
  { item: 'WCAG AA contrast fix — status/success now uses success/700 on success/100 bg (5.66:1)' },
  { item: 'Component pages: Button, Input, Checkbox, Badge, Card, Alert, Status (Spinner + Progress Bar), Tabs' },
  { item: 'Live React demos for all v1 components with full keyboard accessibility' },
  { item: 'Built with Cedar — DayLog real-world usage' },
  { item: 'Roadmap page (this page)' },
  { item: 'Deployed to Vercel' },
];

const v2a = [
  { item: 'Modal — portal dialog with focus trap, Escape, and backdrop close' },
  { item: 'Toast — context-based notification stack with 5 variants and auto-dismiss' },
  { item: 'Tooltip — positioned overlay with getBoundingClientRect placement' },
  { item: 'Breadcrumb — nav landmark with aria-current="page" on active item' },
  { item: 'Pagination — ellipsis compression, keyboard nav, prev/next controls' },
  { item: 'Menu — dropdown with keyboard navigation, dividers, labels, destructive items' },
];

const v2b = [
  { item: 'Select — full combobox ARIA pattern with aria-activedescendant and SelectField wrapper' },
  { item: 'Toggle — role="switch" binary control in sm/md with animated thumb' },
  { item: 'Radio — native input pattern mirroring Checkbox; RadioGroup with fieldset+legend' },
  { item: 'Icon Button — square button sharing Button\'s variant × color system; aria-label required' },
  { item: 'Avatar — initials with deterministic color palette, status dot, AvatarGroup stacking' },
  { item: 'Divider — horizontal/vertical, 3 variants, optional centered label' },
];

const v3Components = [
  'Data Grid',
];

const v2Features = [
  { item: 'Dark mode', detail: 'Figma semantic layer already has one mode — adding a second is the design work. CSS variables make the implementation straightforward.' },
  { item: 'Interactive prop editor', detail: 'Live knobs panel on component pages — change size, color, state without editing code.' },
  { item: 'Typography specimen page', detail: 'Full typeface showcase with Inter weight samples and Fira Code ligature examples.' },
  { item: 'Token export (CSS, JSON)', detail: 'Download Cedar tokens as CSS custom properties or W3C design token JSON.' },
  { item: 'Search', detail: 'Full-text search across token names, component names, and descriptions.' },
  { item: 'Figma embed', detail: 'Live Figma frame embeds on component pages for design—dev comparison.' },
  { item: 'Storybook integration', detail: 'Auto-generated stories from Cedar component props. Best added once all v2 React components exist.' },
];
---

<BaseLayout title="Roadmap">
  <PageHeader
    eyebrow="What's planned"
    title="Roadmap"
    description="Cedar v1 and v2 are both shipped — 20 components documented with live React demos. v2c features and Data Grid are the remaining scope."
  />

  <PageContent>
    <section>
      <div class="version-header">
        <h2 class="version-title">v1 — Shipped</h2>
        <Badge color="success" badgeStyle="subtle" client:load>Current</Badge>
      </div>
      <div class="item-list">
        {v1.map(item => (
          <div class="item-row done">
            <span class="item-check" aria-hidden="true">✓</span>
            <span class="item-text">{item.item}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <div class="version-header">
        <h2 class="version-title">v2a — Components</h2>
        <Badge color="success" badgeStyle="subtle" client:load>Shipped</Badge>
      </div>
      <p class="version-desc">
        Six components with no prior doc page, prioritised by Cedar Ops coverage gaps.
      </p>
      <div class="item-list">
        {v2a.map(item => (
          <div class="item-row done">
            <span class="item-check" aria-hidden="true">✓</span>
            <span class="item-text">{item.item}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <div class="version-header">
        <h2 class="version-title">v2b — Components</h2>
        <Badge color="success" badgeStyle="subtle" client:load>Shipped</Badge>
      </div>
      <p class="version-desc">
        Six components following patterns already established in v1 — lower urgency, same quality bar.
      </p>
      <div class="item-list">
        {v2b.map(item => (
          <div class="item-row done">
            <span class="item-check" aria-hidden="true">✓</span>
            <span class="item-text">{item.item}</span>
          </div>
        ))}
      </div>
    </section>

    <section>
      <div class="version-header">
        <h2 class="version-title">v3 — Components</h2>
        <Badge color="default" badgeStyle="subtle" client:load>Future</Badge>
      </div>
      <p class="version-desc">
        Architecturally distinct from a standard component page — Data Grid is a product feature
        with two Figma architectures (row-oriented and column-oriented), instance-swap cell content,
        toolbar, footer, and pagination integration. Scoped separately to reflect the build investment.
      </p>
      <div class="chip-grid">
        {v3Components.map(name => (
          <span class="component-chip chip-v3">{name}</span>
        ))}
      </div>
    </section>

    <section>
      <div class="version-header">
        <h2 class="version-title">v2c — Features</h2>
        <Badge color="information" badgeStyle="subtle" client:load>Up next</Badge>
      </div>
      <div class="feature-list">
        {v2Features.map(f => (
          <div class="feature-row">
            <h3 class="feature-name">{f.item}</h3>
            <p class="feature-detail">{f.detail}</p>
          </div>
        ))}
      </div>
    </section>
  </PageContent>
</BaseLayout>

<style>
  .version-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .version-title {
    font-size: var(--heading-lg);
    font-weight: 700;
    color: var(--text-base);
  }

  .version-desc {
    font-size: var(--body-md);
    color: var(--text-subtle);
    line-height: 1.6;
    max-width: 560px;
    margin-bottom: var(--space-4);
  }

  .item-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .item-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    background: var(--bg-base);
    border: var(--border-width-base) solid var(--border-subtle);
  }

  .item-check {
    color: var(--status-success);
    font-weight: 700;
    flex-shrink: 0;
    width: 16px;
  }

  .item-text {
    font-size: var(--body-sm);
    color: var(--text-base);
  }

  .chip-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .component-chip {
    font-size: var(--body-sm);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: var(--bg-muted);
    color: var(--text-subtle);
    border: var(--border-width-base) solid var(--border-subtle);
  }

  .chip-v3 {
    background: var(--bg-faint);
    color: var(--text-subtle);
    border-style: dashed;
  }

  .feature-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-base);
  }

  .feature-row {
    padding: var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .feature-row:last-child { border-bottom: none; }
  .feature-row:hover { background: var(--bg-faint); }

  .feature-name {
    font-size: var(--body-md);
    font-weight: 600;
    color: var(--text-base);
  }

  .feature-detail {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    line-height: 1.5;
    max-width: 600px;
  }
</style>
