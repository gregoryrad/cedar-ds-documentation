---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import PageContent from '../components/PageContent.astro';
import { Badge } from '../cedar/components/Badge/Badge';
import { Button } from '../cedar/components/Button/Button';
import { Card } from '../cedar/components/Card/Card';
---

<BaseLayout title="Built with Cedar">
  <PageHeader
    eyebrow="Real-world usage"
    title="Built with Cedar"
    description="Cedar isn't a demo system. Cedar Ops and DayLog are production apps built entirely on Cedar tokens and components, proving the system holds up under real product requirements."
  />

  <PageContent>
    <div class="apps-grid">
      <Card cardStyle="elevated" client:load>
        <div class="app-card">
          <div class="app-header">
            <div>
              <h2 class="app-name">Cedar Ops</h2>
              <div class="app-badges">
                <Badge color="success" badgeStyle="subtle" size="sm" client:load>Live app</Badge>
                <Badge color="information" badgeStyle="subtle" size="sm" client:load>22/23 components</Badge>
                <Badge color="default" badgeStyle="subtle" size="sm" client:load>Cedar tokens</Badge>
              </div>
            </div>
          </div>
          <p class="app-desc">
            A design system adoption dashboard — component tables, detail pages, and
            settings, built to exercise nearly every Cedar component in production.
          </p>
          <Button color="brand" variant="outlined" client:load>
            <a href="https://cedar-ds-ops.vercel.app" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: none;">
              View Cedar Ops
            </a>
          </Button>
        </div>
      </Card>

      <Card cardStyle="elevated" client:load>
        <div class="app-card">
          <div class="app-header">
            <div>
              <h2 class="app-name">DayLog</h2>
              <div class="app-badges">
                <Badge color="success" badgeStyle="subtle" size="sm" client:load>Live app</Badge>
                <Badge color="information" badgeStyle="subtle" size="sm" client:load>PWA</Badge>
                <Badge color="default" badgeStyle="subtle" size="sm" client:load>Cedar tokens</Badge>
              </div>
            </div>
          </div>
          <p class="app-desc">
            A personal productivity PWA built from day one on Cedar's token and component
            system. Every color, space, and interactive state comes directly from Cedar —
            no one-offs, no hardcoded values.
          </p>
          <Button color="brand" variant="outlined" client:load>
            <a href="https://daylog-mu.vercel.app" target="_blank" rel="noopener noreferrer" style="color: inherit; text-decoration: none;">
              View DayLog
            </a>
          </Button>
        </div>
      </Card>
    </div>

    <section class="tokens-used">
      <h2 class="section-title">What Cedar tokens these apps use</h2>
      <div class="token-list">
        {[
          { category: 'Color / Semantic', detail: 'bg/base, bg/faint, text/base, text/subtle, action/primary, status/*' },
          { category: 'Space / Scale',    detail: 'space/2 through space/8 for all padding and gap values' },
          { category: 'Radius',           detail: 'radius/md for inputs, radius/lg for cards, radius/full for badges' },
          { category: 'Typography',       detail: 'body/sm and body/md for all UI text; heading/* for section titles' },
          { category: 'Border',           detail: 'border-width/base + border/subtle for all card and input borders' },
        ].map(item => (
          <div class="token-list-row">
            <code class="token-cat">{item.category}</code>
            <p class="token-detail">{item.detail}</p>
          </div>
        ))}
      </div>
    </section>
  </PageContent>
</BaseLayout>

<style>
  .apps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  @media (max-width: 700px) {
    .apps-grid {
      grid-template-columns: 1fr;
    }
  }

  .app-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .app-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
  }

  .app-name {
    font-size: var(--title-sm);
    font-weight: 700;
    color: var(--text-base);
    margin-bottom: var(--space-2);
  }

  .app-badges {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .app-desc {
    font-size: var(--body-md);
    color: var(--text-subtle);
    line-height: 1.6;
    max-width: 560px;
  }

  .tokens-used {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .section-title {
    font-size: var(--heading-lg);
    font-weight: 700;
    color: var(--text-base);
  }

  .token-list {
    border: var(--border-width-base) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-base);
  }

  .token-list-row {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-bottom: var(--border-width-base) solid var(--border-subtle);
    align-items: center;
  }

  .token-list-row:last-child { border-bottom: none; }
  .token-list-row:hover { background: var(--bg-faint); }

  .token-cat {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    color: var(--text-base);
    font-weight: 600;
  }

  .token-detail {
    font-size: var(--body-sm);
    color: var(--text-subtle);
    line-height: 1.4;
  }
</style>
